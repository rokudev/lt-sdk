+################################################################################
+# Makefile - dhrystone libdhry2_1.a makefile
+#
+# Copyright 2026, Roku, Inc.  All rights reserved.
+################################################################################
+
+.PHONY: all
+all:
+	mkdir -p lib
+	rm -f lib/libdhry_2.1.a
+	$(CC) $(CFLAGS) -c dhry_1.c -o dhry_1.o
+	$(CC) $(CFLAGS) -c dhry_2.c -o dhry_2.o
+	$(AR) $(ARFLAGS) lib/libdhry_2.1.a dhry_1.o dhry_2.o
